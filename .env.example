NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
SERVICE_NAME=amrutam-backend
APP_VERSION=1.0.0

DATABASE_URL=postgresql://amrutam:amrutam_secret@localhost:5432/amrutam?schema=public&connection_limit=20&pool_timeout=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
PASSWORD_HISTORY_COUNT=5

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

CORS_ORIGINS=http://localhost:3000,http://localhost:4200

SWAGGER_ENABLED=true
MFA_ENABLED=true
MFA_ENCRYPTION_KEY=change-me-mfa-encryption-key-min-32-chars!!

BOOKING_CANCELLATION_HOURS=24

PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret-min-32-chars-long
PAYMENT_PROVIDER=MOCK

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
METRICS_ENABLED=true
PROMETHEUS_PORT=9464

SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=500
MAX_HEAP_USED_MB=512
MAX_PAYLOAD_SIZE=1mb

CACHE_DEFAULT_TTL_SECONDS=60
CACHE_LOCK_TTL_SECONDS=10
